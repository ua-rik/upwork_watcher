{
  "name": "upwork-watcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "once": "tsx src/cli.ts",
    "test": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "commander": "^11.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.27.2",
    "graphql-request": "^6.1.0",
    "nodemailer": "^6.9.11",
    "openai": "^4.55.4",
    "pino": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "prisma": "^5.15.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "lint-staged": {
    "*.ts": ["eslint --fix", "prettier --write", "vitest related" ]
  }
}
